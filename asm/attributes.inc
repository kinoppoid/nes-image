; PPU attribute table bytes for the 16x16 tile image region.
;
; The image occupies screen tiles col 8..23, row 1..16.
;   -> attribute byte columns 2..5 (each attr col = 4 tile cols)
;   -> attribute byte rows    0..3 (each attr row = 4 tile rows)
;
; Attribute byte bit layout:
;   [1:0] = top-left  2x2 tile quadrant palette index
;   [3:2] = top-right 2x2 tile quadrant palette index
;   [5:4] = bottom-left  2x2 tile quadrant palette index
;   [7:6] = bottom-right 2x2 tile quadrant palette index
;
; To write to PPU: for each row r (0..3),
;   write the 4 bytes to $23C0 + r*8 + 2

image_attributes:
  .byte $55,$95,$A5,$05  ; attr row 0: TL=1 TR=1 BL=1 BR=1  TL=1 TR=1 BL=1 BR=2  TL=1 TR=1 BL=2 BR=2  TL=1 TR=1 BL=0 BR=0
  .byte $F5,$CB,$3A,$6E  ; attr row 1: TL=1 TR=1 BL=3 BR=3  TL=3 TR=2 BL=0 BR=3  TL=2 TR=2 BL=3 BR=0  TL=2 TR=3 BL=2 BR=1
  .byte $3F,$0F,$2F,$55  ; attr row 2: TL=3 TR=3 BL=3 BR=0  TL=3 TR=3 BL=0 BR=0  TL=3 TR=3 BL=2 BR=0  TL=1 TR=1 BL=1 BR=1
  .byte $51,$50,$5C,$55  ; attr row 3: TL=1 TR=0 BL=1 BR=1  TL=0 TR=0 BL=1 BR=1  TL=0 TR=3 BL=1 BR=1  TL=1 TR=1 BL=1 BR=1
